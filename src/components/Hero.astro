---
---
<section
  id="inicio"
  class="snap-start min-h-screen relative flex items-center justify-center pt-16"
>
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1438032005730-c779502df39b?auto=format&fit=crop&q=80&w=1920&h=1080"
      alt="Iglesia adoración"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gray-900/60 mix-blend-multiply"></div>
  </div>

  <div
    class="relative z-10 text-center px-6 max-w-4xl mx-auto flex flex-col items-center"
  >
    <h1
      class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white mb-6 drop-shadow-md"
    >
      Bienvenidos a <br />
      <span class="text-blue-400">UCB Cristo al Mundo</span>
    </h1>
    <p class="text-lg md:text-2xl text-gray-200 mb-10 max-w-2xl font-light">
      Una comunidad unida por el amor de Cristo, apasionada por Su Palabra y
      comprometida con nuestra ciudad.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
      <a
        href="#contacto"
        class="bg-blue-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-blue-700 hover:scale-105 transition-all shadow-lg active:scale-95"
      >
        Saber más sobre la iglesia
      </a>
      <a
        href="#predicas"
        class="bg-white/10 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-full font-semibold text-lg hover:bg-white/20 hover:scale-105 transition-all outline-none"
      >
        Escuchar prédicas
      </a>
    </div>
  </div>
</section>
