---

---

<footer
  class="snap-end bg-gray-950 pt-20 pb-10 border-t border-gray-800 text-gray-400"
>
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <!-- Columna 1: Branding y Misión -->
      <div class="space-y-6">
        <a
          href="#inicio"
          class="text-2xl font-bold tracking-tighter text-white inline-block mb-2"
        >
          UCB <span class="font-light text-blue-500">Cristo al Mundo</span>
        </a>
        <p class="text-sm leading-relaxed text-gray-400">
          Somos una iglesia bíblica comprometida con la proclamación del
          Evangelio de Jesucristo. Nuestra misión es adorar a Dios, edificar a
          los creyentes y servir a nuestra comunidad.
        </p>
      </div>

      <!-- Columna 2: Enlaces Rápidos -->
      <div>
        <h4
          class="text-white font-semibold mb-6 uppercase text-sm tracking-wider"
        >
          La Iglesia
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              href="/quienes-somos"
              class="hover:text-blue-400 transition-colors">Quiénes Somos</a
            >
          </li>
          <li>
            <a
              href="/interno/declaracion-doctrinal"
              class="hover:text-blue-400 transition-colors"
              >Nuestra Doctrina (Declaración de Fe)</a
            >
          </li>
          <li>
            <a
              href="/interno/estatutos-legales"
              class="hover:text-blue-400 transition-colors">Estatutos Legales</a
            >
          </li>
          <li>
            <a
              href="/interno/reglamento-interno"
              class="hover:text-blue-400 transition-colors"
              >Reglamento Interno</a
            >
          </li>
          <li>
            <a href="/ministerios" class="hover:text-blue-400 transition-colors"
              >Ministerios</a
            >
          </li>
          <li>
            <a href="/organigrama" class="hover:text-blue-400 transition-colors"
              >Organigrama</a
            >
          </li>
        </ul>
      </div>

      <!-- Columna 3: Contacto -->
      <div>
        <h4
          class="text-white font-semibold mb-6 uppercase text-sm tracking-wider"
        >
          Contacto
        </h4>
        <ul class="space-y-3">
          <li class="flex items-center">
            <svg
              class="w-4 h-4 mr-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
            >
            Merced 769, Melipilla.
          </li>
          <li class="flex items-center">
            <svg
              class="w-4 h-4 mr-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
            +56 2 2123 4567
          </li>
          <li class="flex items-center">
            <svg
              class="w-4 h-4 mr-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
            contacto@ucbcristoalmundo.cl
          </li>
        </ul>
      </div>

      <!-- Columna 4: Redes Sociales -->
      <div>
        <h4
          class="text-white font-semibold mb-6 uppercase text-sm tracking-wider"
        >
          Síguenos
        </h4>
        <div class="flex space-x-4">
          <!-- Facebook -->
          <a
            href="#"
            class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path></svg
            >
          </a>
          <!-- Instagram -->
          <a
            href="#"
            class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-pink-600 hover:text-white transition-all"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
              ></path></svg
            >
          </a>
          <!-- YouTube -->
          <a
            href="#"
            class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-red-600 hover:text-white transition-all"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"
              ></path></svg
            >
          </a>
        </div>
      </div>
    </div>

    <div
      class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center"
    >
      <p class="text-sm">
        &copy; {new Date().getFullYear()} Iglesia UCB Cristo al Mundo. Todos los derechos
        reservados.
      </p>
      <p class="text-sm mt-4 md:mt-0 text-gray-500">
        Diseñado con propósito en Cristo.
      </p>
    </div>
  </div>
</footer>
