---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Organigrama - UCB Cristo al Mundo">
  <Header />

  <main class="h-screen overflow-y-scroll bg-gray-50 pt-24">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-h-screen flex flex-col pb-12"
    >
      <div class="text-center mb-16">
        <h1
          class="text-4xl md:text-5xl font-extrabold text-gray-900 tracking-tight mb-4"
        >
          Organigrama de la Iglesia
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Jerarquía, liderazgo y servidores de nuestra congregación
        </p>
      </div>

      <div class="grow flex flex-col items-center space-y-10 relative w-full">
        <!-- 1. Pastor Asesor -->
        <div class="w-full flex justify-center">
          <div
            class="bg-white shadow-xl rounded-2xl p-6 border-t-4 border-blue-600 w-full max-w-sm text-center transform transition duration-300 hover:-translate-y-1 hover:shadow-2xl"
          >
            <span
              class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-2 block"
              >Pastor Asesor</span
            >
            <h2 class="text-2xl font-bold text-gray-900">Hernán Contreras</h2>
          </div>
        </div>

        <!-- 2. Ancianos -->
        <div
          class="w-full flex flex-col md:flex-row justify-center items-center gap-6"
        >
          <div
            class="bg-white shadow-lg rounded-xl p-6 border-t-4 border-indigo-500 w-full max-w-xs text-center transform transition duration-300 hover:-translate-y-1 hover:shadow-xl"
          >
            <span
              class="text-xs font-bold tracking-widest text-indigo-500 uppercase mb-2 block"
              >Anciano</span
            >
            <h3 class="text-xl font-bold text-gray-800">Carlos Liempi</h3>
          </div>
          <div
            class="bg-white shadow-lg rounded-xl p-6 border-t-4 border-indigo-500 w-full max-w-xs text-center transform transition duration-300 hover:-translate-y-1 hover:shadow-xl"
          >
            <span
              class="text-xs font-bold tracking-widest text-indigo-500 uppercase mb-2 block"
              >Anciano</span
            >
            <h3 class="text-xl font-bold text-gray-800">Jonathan Palma</h3>
          </div>
        </div>

        <!-- 3. Tesorero y Secretaria -->
        <div
          class="w-full flex flex-col md:flex-row justify-center items-center gap-6"
        >
          <div
            class="bg-white shadow-md rounded-xl p-5 border-t-4 border-teal-500 w-full max-w-xs text-center transform transition duration-300 hover:-translate-y-1 hover:shadow-lg"
          >
            <span
              class="text-xs font-bold tracking-widest text-teal-500 uppercase mb-1 block"
              >Tesorero</span
            >
            <h3 class="text-lg font-bold text-gray-800">Ricardo Fuentes</h3>
          </div>
          <div
            class="bg-white shadow-md rounded-xl p-5 border-t-4 border-teal-500 w-full max-w-xs text-center transform transition duration-300 hover:-translate-y-1 hover:shadow-lg"
          >
            <span
              class="text-xs font-bold tracking-widest text-teal-500 uppercase mb-1 block"
              >Secretaria</span
            >
            <h3 class="text-lg font-bold text-gray-800">Nicole Herrera</h3>
          </div>
        </div>

        <!-- 4. Diáconos, Diaconisas y Ministerios -->
        <div class="w-full grid grid-cols-1 md:grid-cols-3 gap-8 mt-6">
          <!-- Diáconos -->
          <div
            class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100 transform transition duration-300 hover:-translate-y-1 hover:shadow-xl flex flex-col"
          >
            <div class="bg-slate-800 px-6 py-4">
              <h3
                class="text-lg font-bold text-white text-center uppercase tracking-widest"
              >
                Diáconos
              </h3>
            </div>
            <ul class="divide-y divide-gray-100 px-6 py-2 grow">
              <li class="py-3 text-gray-700 font-medium text-center">
                Ricardo Fuentes
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Juan Iturra
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Víctor Jofré
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Carlos Dunarri
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Alejandro Alvarado
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Christopher Rojas
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Pablo García
              </li>
            </ul>
          </div>

          <!-- Diaconisas -->
          <div
            class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100 transform transition duration-300 hover:-translate-y-1 hover:shadow-xl flex flex-col"
          >
            <div class="bg-slate-700 px-6 py-4">
              <h3
                class="text-lg font-bold text-white text-center uppercase tracking-widest"
              >
                Diaconisas
              </h3>
            </div>
            <ul class="divide-y divide-gray-100 px-6 py-2 grow">
              <li class="py-3 text-gray-700 font-medium text-center">
                Carolina Vargas
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Mylene Pérez
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Tamara Santander
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Paula Maldonado
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Jocelyn Ayenao
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Rosa Muñoz
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Victoria Torres
              </li>
              <li class="py-3 text-gray-700 font-medium text-center">
                Damaridt Torres
              </li>
            </ul>
          </div>

          <!-- Ministerios -->
          <div
            class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100 transform transition duration-300 hover:-translate-y-1 hover:shadow-xl flex flex-col"
          >
            <div class="bg-emerald-600 px-6 py-4">
              <h3
                class="text-lg font-bold text-white text-center uppercase tracking-widest"
              >
                Líderes de Ministerios
              </h3>
            </div>
            <ul class="divide-y divide-gray-100 px-6 py-2 grow">
              <li class="py-3 flex flex-col items-center text-center">
                <span class="text-xs text-emerald-600 font-bold uppercase mb-1"
                  >Jóvenes (JPC)</span
                >
                <span class="text-gray-800 font-medium">Juan Iturra</span>
              </li>
              <li class="py-3 flex flex-col items-center text-center">
                <span class="text-xs text-emerald-600 font-bold uppercase mb-1"
                  >Alabanza</span
                >
                <span class="text-gray-800 font-medium">Cristopher Rojas</span>
              </li>
              <li class="py-3 flex flex-col items-center text-center">
                <span class="text-xs text-emerald-600 font-bold uppercase mb-1"
                  >Audiovisual (Alabanza)</span
                >
                <span class="text-gray-800 font-medium">Ricardo Fuentes</span>
              </li>
              <li class="py-3 flex flex-col items-center text-center">
                <span class="text-xs text-emerald-600 font-bold uppercase mb-1"
                  >Escuela Dominical</span
                >
                <span class="text-gray-800 font-medium"
                  >Paula Vivar y Paula Maldonado</span
                >
              </li>
              <li class="py-3 flex flex-col items-center text-center">
                <span class="text-xs text-emerald-600 font-bold uppercase mb-1"
                  >Diaconado</span
                >
                <span class="text-gray-800 font-medium"
                  >Ricardo Fuentes y Carola Vargas</span
                >
              </li>
              <li class="py-3 flex flex-col items-center text-center">
                <span class="text-xs text-emerald-600 font-bold uppercase mb-1"
                  >Damas</span
                >
                <span class="text-gray-800 font-medium"
                  >Carola Vargas, Eva Meza y Victoria Torres</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <Footer />
  </main>

  <style>
    /* Hide scrollbar for the vertical container but keep functionality */
    main::-webkit-scrollbar {
      width: 8px;
    }
    main::-webkit-scrollbar-track {
      background: transparent;
    }
    main::-webkit-scrollbar-thumb {
      background-color: rgba(156, 163, 175, 0.5);
      border-radius: 20px;
    }
  </style>
</Layout>
