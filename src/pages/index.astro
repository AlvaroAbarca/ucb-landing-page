---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Horarios from "../components/Horarios.astro";
import Predicas from "../components/Predicas.astro";
import Contacto from "../components/Contacto.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="UCB Cristo al Mundo">
  <Header />

  <main class="md:snap-y md:snap-mandatory h-screen overflow-y-scroll">
    <Hero />
    <Horarios />
    <Predicas />
    <Contacto />
    <Footer />
  </main>

  <style>
    /* Hide scrollbar for the vertical snap container but keep functionality */
    main::-webkit-scrollbar {
      width: 8px;
    }
    main::-webkit-scrollbar-track {
      background: transparent;
    }
    main::-webkit-scrollbar-thumb {
      background-color: rgba(156, 163, 175, 0.5);
      border-radius: 20px;
    }
  </style>
</Layout>
