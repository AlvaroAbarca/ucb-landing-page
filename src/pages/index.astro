---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Horarios from "../components/Horarios.astro";
import Predicas from "../components/Predicas.astro";
import Contacto from "../components/Contacto.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="UCB Cristo al Mundo">
  <Header />

  <main class="md:snap-y md:snap-mandatory h-screen overflow-y-scroll">
    <Hero />
    <Horarios />
    <Predicas />
    <Contacto />
    <Footer />
  </main>

  <script>
    const mainContainer = document.querySelector("main");
    if (mainContainer) {
      // Find all direct children of main that have an id
      const sections = Array.from(mainContainer.children).filter((child) => child.id);

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              if (id) {
                history.replaceState(null, "", `#${id}`);
              }
            }
          });
        },
        {
          root: mainContainer,
          threshold: 0.5, // Trigger when 50% of the section is visible
        }
      );

      sections.forEach((section) => observer.observe(section));

      // Handle initial load if there's a hash in the URL
      const hash = window.location.hash;
      if (hash) {
        const target = document.querySelector(hash);
        if (target && mainContainer.contains(target)) {
          setTimeout(() => {
            target.scrollIntoView({ behavior: "smooth" });
          }, 100);
        }
      }
    }
  </script>

  <style>
    /* Hide scrollbar for the vertical snap container but keep functionality */
    main::-webkit-scrollbar {
      width: 8px;
    }
    main::-webkit-scrollbar-track {
      background: transparent;
    }
    main::-webkit-scrollbar-thumb {
      background-color: rgba(156, 163, 175, 0.5);
      border-radius: 20px;
    }
  </style>
</Layout>
