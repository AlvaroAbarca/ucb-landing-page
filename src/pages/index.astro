---
import Layout from "../layouts/Layout.astro";

// Datos de prueba (placeholders)
const reuniones = [
  {
    titulo: "Culto de Adoración Dominical",
    dia: "Domingo",
    hora: "11:00 AM",
    descripcion:
      "Nuestro servicio principal de alabanza y predicación de la Palabra.",
  },
  {
    titulo: "Escuela Dominical",
    dia: "Domingo",
    hora: "10:00 AM",
    descripcion:
      "Clases bíblicas para todas las edades antes del culto principal.",
  },
  {
    titulo: "Reunión de Oración",
    dia: "Miércoles",
    hora: "19:30 PM",
    descripcion:
      "Un tiempo dedicado a buscar la presencia de Dios en comunión.",
  },
  {
    titulo: "Grupo de Jóvenes",
    dia: "Sábado",
    hora: "18:00 PM",
    descripcion: "Reunión dinámica para adolescentes y jóvenes.",
  },
];

const predicas = [
  {
    titulo: "El Poder de la Fe",
    predicador: "Pr. Juan Pérez",
    fecha: "12 Noviembre, 2023",
    imagen:
      "https://images.unsplash.com/photo-1438032005730-c779502df39b?auto=format&fit=crop&q=80&w=600&h=400",
    url: "https://youtube.com",
  },
  {
    titulo: "Caminando en Amor",
    predicador: "Pr. Pedro Gómez",
    fecha: "05 Noviembre, 2023",
    imagen:
      "https://images.unsplash.com/photo-1504052434569-70ad5836ab65?auto=format&fit=crop&q=80&w=600&h=400",
    url: "https://youtube.com",
  },
  {
    titulo: "Esperanza en Tiempos Difíciles",
    predicador: "Pr. Juan Pérez",
    fecha: "29 Octubre, 2023",
    imagen:
      "https://images.unsplash.com/photo-1490730141103-6cac27aaab94?auto=format&fit=crop&q=80&w=600&h=400",
    url: "https://youtube.com",
  },
];
---

<Layout title="UCB Cristo al Mundo">
  <!-- Navbar Fija para facilitar el desplazamiento -->
  <header
    class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur-md shadow-sm"
  >
    <nav class="container mx-auto px-6 py-4 flex justify-between items-center">
      <a
        href="#inicio"
        class="text-xl font-bold tracking-tighter text-blue-900"
      >
        UCB <span class="font-light text-blue-600">Cristo al Mundo</span>
      </a>
      <ul class="hidden md:flex space-x-8 text-sm font-medium text-gray-700">
        <li>
          <a href="#inicio" class="hover:text-blue-600 transition-colors"
            >Inicio</a
          >
        </li>
        <li>
          <a href="#horarios" class="hover:text-blue-600 transition-colors"
            >Horarios</a
          >
        </li>
        <li>
          <a href="#predicas" class="hover:text-blue-600 transition-colors"
            >Prédicas</a
          >
        </li>
        <li>
          <a href="#contacto" class="hover:text-blue-600 transition-colors"
            >Contacto</a
          >
        </li>
      </ul>
      <a
        href="#contacto"
        class="hidden md:inline-flex bg-blue-600 text-white px-5 py-2 rounded-full text-sm font-medium hover:bg-blue-700 transition-colors"
      >
        Visítanos
      </a>
    </nav>
  </header>

  <main class="snap-y snap-mandatory h-screen overflow-y-scroll">
    <!-- Sección 1: Recepción (Hero Section) -->
    <section
      id="inicio"
      class="snap-start min-h-screen relative flex items-center justify-center pt-16"
    >
      <div class="absolute inset-0 z-0">
        <img
          src="https://images.unsplash.com/photo-1438032005730-c779502df39b?auto=format&fit=crop&q=80&w=1920&h=1080"
          alt="Iglesia adoración"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gray-900/60 mix-blend-multiply"></div>
      </div>

      <div
        class="relative z-10 text-center px-6 max-w-4xl mx-auto flex flex-col items-center"
      >
        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white mb-6 drop-shadow-md"
        >
          Bienvenidos a <br />
          <span class="text-blue-400">UCB Cristo al Mundo</span>
        </h1>
        <p class="text-lg md:text-2xl text-gray-200 mb-10 max-w-2xl font-light">
          Una comunidad unida por el amor de Cristo, apasionada por Su Palabra y
          comprometida con nuestra ciudad.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
          <a
            href="#contacto"
            class="bg-blue-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-blue-700 hover:scale-105 transition-all shadow-lg active:scale-95"
          >
            Saber más sobre la iglesia
          </a>
          <a
            href="#predicas"
            class="bg-white/10 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-full font-semibold text-lg hover:bg-white/20 hover:scale-105 transition-all outline-none"
          >
            Escuchar prédicas
          </a>
        </div>
      </div>
    </section>

    <!-- Sección 2: Horarios y Reuniones -->
    <section
      id="horarios"
      class="snap-start min-h-screen flex items-center bg-gray-50 pt-20 pb-12"
    >
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">
            Nuestros Horarios
          </h2>
          <div class="w-24 h-1 bg-blue-600 mx-auto rounded-full mb-6"></div>
          <p class="text-gray-600 max-w-2xl mx-auto text-lg">
            Te invitamos a ser parte de nuestras actividades semanales. Hay un
            lugar para ti en nuestra congregación.
          </p>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto"
        >
          {
            reuniones.map((reunion) => (
              <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all group">
                <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                  <svg
                    class="w-7 h-7"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">
                  {reunion.titulo}
                </h3>
                <div class="flex items-center text-blue-600 font-semibold mb-4 space-x-2">
                  <span>{reunion.dia}</span>
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-600" />
                  <span>{reunion.hora}</span>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  {reunion.descripcion}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Sección 3: Últimas Prédicas -->
    <section
      id="predicas"
      class="snap-start min-h-screen flex items-center bg-white pt-20 pb-12"
    >
      <div class="container mx-auto px-6">
        <div
          class="flex flex-col md:flex-row justify-between items-end mb-12 max-w-6xl mx-auto"
        >
          <div>
            <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">
              Últimas Prédicas
            </h2>
            <div class="w-24 h-1 bg-blue-600 rounded-full mb-6"></div>
            <p class="text-gray-600 max-w-xl text-lg">
              Aliméntate de la Palabra de Dios a través de nuestros estudios y
              sermones recientes.
            </p>
          </div>
          <a
            href="https://www.youtube.com/@iglesiaucbcristoalmundo"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden md:flex items-center text-red-600 font-semibold hover:text-red-700 transition-colors"
          >
            Ver canal completo
            <svg
              class="w-5 h-5 ml-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto"
        >
          {
            predicas.map((predica) => (
              <div class="bg-gray-50 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all flex flex-col group">
                <div class="relative h-60 overflow-hidden">
                  <img
                    src={predica.imagen}
                    alt={predica.titulo}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                  <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors duration-500" />
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <a
                      href={predica.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="bg-red-600 text-white w-14 h-14 rounded-full flex items-center justify-center hover:scale-110 hover:bg-red-700 shadow-lg transition-all"
                    >
                      <svg
                        class="w-7 h-7 ml-1"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z" />
                      </svg>
                    </a>
                  </div>
                </div>
                <div class="p-6 flex-1 flex flex-col">
                  <div class="flex items-center text-xs font-semibold text-blue-600 mb-3 tracking-wider uppercase">
                    <span>{predica.fecha}</span>
                  </div>
                  <h3 class="text-xl font-bold text-gray-900 mb-2">
                    {predica.titulo}
                  </h3>
                  <p class="text-gray-600 mt-auto flex items-center">
                    <svg
                      class="w-4 h-4 mr-2"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                      />
                    </svg>
                    {predica.predicador}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Sección 4: Ubicación y Contacto -->
    <section
      id="contacto"
      class="snap-start min-h-screen flex flex-col md:flex-row bg-white relative"
    >
      <!-- Mitad Izquierda: Info de Contacto -->
      <div
        class="flex-1 flex flex-col justify-center px-8 py-16 md:px-16 lg:px-24 bg-blue-900 text-white pt-24 md:pt-16"
      >
        <div class="max-w-md mx-auto md:mx-0">
          <div class="flex items-center mb-8">
            <div
              class="w-16 h-16 bg-white text-blue-900 rounded-full flex items-center justify-center font-bold text-2xl shadow-lg mr-4"
            >
              UCB
            </div>
            <h2 class="text-3xl font-bold">Cristo al Mundo</h2>
          </div>

          <h3
            class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight text-white leading-tight"
          >
            Estamos para <span class="text-blue-300">servirte</span>
          </h3>
          <div class="w-20 h-1 bg-blue-400 rounded-full mb-8"></div>

          <p class="text-blue-100 text-lg mb-10 leading-relaxed font-light">
            Te invitamos a ser parte de nuestra comunidad. Si tienes alguna
            duda, petición de oración o necesitas más información, no dudes en
            visitarnos o contactarnos.
          </p>

          <div class="space-y-6">
            <div class="flex items-start">
              <svg
                class="w-6 h-6 text-blue-300 mt-1 mr-4 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <div>
                <h4 class="font-semibold text-white mb-1">Dirección Física</h4>
                <p class="text-blue-200">
                  Merced 769, <br />Melipilla, Región Metropolitana.
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <svg
                class="w-6 h-6 text-blue-300 mt-1 mr-4 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              <div>
                <h4 class="font-semibold text-white mb-1">
                  Correo Electrónico
                </h4>
                <p class="text-blue-200">contacto@ucbcristoalmundo.cl</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg
                class="w-6 h-6 text-blue-300 mt-1 mr-4 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              <div>
                <h4 class="font-semibold text-white mb-1">Teléfono Central</h4>
                <p class="text-blue-200">+56 2 2123 4567</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mitad Derecha: Mapa -->
      <div class="flex-1 h-[50vh] md:h-auto w-full">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1m2!1s0x9662cfad9d3d3c81%3A0xe781ab79ff5d7b57!2sVilla%20Santa%20Elena%2C%20Macul%2C%20Regi%C3%B3n%20Metropolitana!5e0!3m2!1ses-419!2scl!4v1700000000000!5m2!1ses-419!2scl"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="grayscale md:grayscale-0 hover:grayscale-0 transition-all duration-500"
        ></iframe>
      </div>
    </section>

    <!-- Sección 5: Footer / Final (se acomoda al final del scroll) -->
    <footer
      class="snap-end bg-gray-950 pt-20 pb-10 border-t border-gray-800 text-gray-400"
    >
      <div class="container mx-auto px-6 max-w-7xl">
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16"
        >
          <!-- Columna 1: Branding y Misión -->
          <div class="space-y-6">
            <a
              href="#inicio"
              class="text-2xl font-bold tracking-tighter text-white inline-block mb-2"
            >
              UCB <span class="font-light text-blue-500">Cristo al Mundo</span>
            </a>
            <p class="text-sm leading-relaxed text-gray-400">
              Somos una iglesia bíblica comprometida con la proclamación del
              Evangelio de Jesucristo. Nuestra misión es adorar a Dios, edificar
              a los creyentes y servir a nuestra comunidad.
            </p>
          </div>

          <!-- Columna 2: Enlaces Rápidos -->
          <div>
            <h4
              class="text-white font-semibold mb-6 uppercase text-sm tracking-wider"
            >
              La Iglesia
            </h4>
            <ul class="space-y-3">
              <li>
                <a href="#" class="hover:text-blue-400 transition-colors"
                  >Quiénes Somos</a
                >
              </li>
              <li>
                <a href="#" class="hover:text-blue-400 transition-colors"
                  >Nuestra Doctrina (Declaración de Fe)</a
                >
              </li>
              <li>
                <a href="#" class="hover:text-blue-400 transition-colors"
                  >Ministerios</a
                >
              </li>
              <li>
                <a href="#" class="hover:text-blue-400 transition-colors"
                  >Donaciones / Ofrendas</a
                >
              </li>
            </ul>
          </div>

          <!-- Columna 3: Contacto -->
          <div>
            <h4
              class="text-white font-semibold mb-6 uppercase text-sm tracking-wider"
            >
              Contacto
            </h4>
            <ul class="space-y-3">
              <li class="flex items-center">
                <svg
                  class="w-4 h-4 mr-3"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
                >
                Merced 769, Melipilla.
              </li>
              <li class="flex items-center">
                <svg
                  class="w-4 h-4 mr-3"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path></svg
                >
                +56 2 2123 4567
              </li>
              <li class="flex items-center">
                <svg
                  class="w-4 h-4 mr-3"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path></svg
                >
                contacto@ucbcristoalmundo.cl
              </li>
            </ul>
          </div>

          <!-- Columna 4: Redes Sociales -->
          <div>
            <h4
              class="text-white font-semibold mb-6 uppercase text-sm tracking-wider"
            >
              Síguenos
            </h4>
            <div class="flex space-x-4">
              <!-- Facebook -->
              <a
                href="#"
                class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                  ></path></svg
                >
              </a>
              <!-- Instagram -->
              <a
                href="#"
                class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-pink-600 hover:text-white transition-all"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
                  ></path></svg
                >
              </a>
              <!-- YouTube -->
              <a
                href="#"
                class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-red-600 hover:text-white transition-all"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
