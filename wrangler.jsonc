{
  "compatibility_date": "2026-04-12",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "name": "ucb-landing-page",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true
}
